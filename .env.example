# Supabase project credentials
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.

SUPABASE_URL=your-project-url
SUPABASE_KEY=your-anon-key

# Flask configuration
FLASK_ENV=development
FLASK_PORT=5000

# Path to the evdev device for the USB RFID door reader (Linux / Mac only).
# Run `ls /dev/input/event*` after plugging in the USB reader to find the path.
# Not used on Windows (the keyboard library handles HID input directly).
RFID_DEVICE=/dev/input/event2

# Room number associated with the USB door RFID reader attached to this machine.
# Each Flask instance manages one physical door unit.
DOOR_ROOM=101
